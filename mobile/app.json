{
  "expo": {
    "name": "BudgetSync",
    "slug": "budgetsync",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "budgetsync",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.budgetsync.app"
